{
  "config": {
    "default": false,

    // Whitespace and structural normalization only — rules whose
    // autofix never touches prose content (emphasis, code spans,
    // heading text, link text, list numbering, capitalization).
    // The .md files in this repo are instructional prose. Any rule
    // whose fix interprets authorial meaning is the wrong kind of
    // assistance and is left out by design.
    "MD005": true, // list-indent (within-list consistency)
    "MD007": {
      "indent": 2
    }, // ul-indent — 2-space matches the repo convention
    "MD009": true, // no-trailing-spaces
    "MD010": true, // no-hard-tabs
    "MD011": true, // no-reversed-links (fixes a syntax mistake, not prose)
    "MD012": true, // no-multiple-blanks
    "MD018": true, // no-missing-space-atx
    "MD019": true, // no-multiple-space-atx
    "MD020": true, // no-missing-space-closed-atx
    "MD021": true, // no-multiple-space-closed-atx
    "MD022": true, // blanks-around-headings
    "MD023": true, // headings-start-left
    "MD027": true, // no-multiple-space-blockquote
    "MD031": true, // blanks-around-fences
    "MD032": true, // blanks-around-lists
    "MD039": true, // no-space-in-links
    "MD047": true, // single-trailing-newline
    "MD058": true // blanks-around-tables
  },
  "ignores": [
    "node_modules/**",
    "**/node_modules/**",
    ".graphify/**",
    "graphify-out/**",
    "plugins/**",
    "projects/**",
    "plans/**",
    "evals/**",
    "agent-memory/**",
    "agents/**",
    "skills/**",
    "workflows/**",
    "shell-snapshots/**",
    "session-env/**",
    "cache/**",
    ".thinkies/**"
  ]
}
