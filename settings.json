{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "includeGitInstructions": true,
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TaskCreate",
      "Bash",
      "Skill",
      "Read(**/.dotty*)",
      "mcp__claude_ai_*",
      "mcp__exa__*",
      "Bash(git status:*)",
      "Bash(git commit:*)",
      "Bash(shfmt:*)",
      "Bash(port installed:*)",
      "Bash(vendor/bats-core/bin/bats:*)",
      "Bash(git add:*)",
      "Bash(bats:*)",
      "Bash(port search:*)",
      "Bash(npx tsc:*)",
      "Bash(git mv:*)"
    ],
    "deny": [
      "Read(~/.kube/**)",
      "Read(**/.*profile)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*credentials*)",
      "Read(**/*secrets*)",
      "Read(**/.env*)",
      "Bash(sudo *)",
      "Bash(rm -rf /*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(chmod 777 *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(curl * | sh)",
      "Bash(curl * | bash)",
      "Bash(wget * | sh)"
    ],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "bash /Users/nke/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "dependency-audit@amboss-skills": true,
    "expression@seed": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "k8s-skills@amboss-skills": false,
    "kotlin-lsp@claude-plugins-official": true,
    "miro@miro-ai": true,
    "nats-skills@amboss-skills": false,
    "perspectives@seed": true,
    "php-lsp@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "sentry@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "software@seed": true,
    "switchboard@seed": true,
    "thinkies@seed": true,
    "typescript-lsp@claude-plugins-official": true,
    "visualizer@seed": false,
    "babysitter@a5c.ai": true
  },
  "extraKnownMarketplaces": {
    "amboss-skills": {
      "source": {
        "source": "github",
        "repo": "amboss-mededu/skills"
      },
      "autoUpdate": true
    },
    "miro-ai": {
      "source": {
        "source": "github",
        "repo": "miroapp/miro-ai"
      }
    },
    "seed": {
      "source": {
        "source": "github",
        "repo": "synapseradio/seed"
      }
    },
    "a5c.ai": {
      "source": {
        "source": "github",
        "repo": "a5c-ai/babysitter"
      }
    }
  },
  "skipWebFetchPreflight": true,
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "registry.npmjs.org",
        "*.npmjs.org",
        "pypi.org",
        "*.pythonhosted.org"
      ]
    },
    "filesystem": {
      "allowWrite": [
        "//tmp"
      ],
      "denyRead": [
        "~/.kube",
        "~/.aws",
        "~/.gnupg",
        "~/.ssh",
        "~/.zshrc",
        "~/.npmrc"
      ]
    },
    "enableWeakerNetworkIsolation": true,
    "excludedCommands": [
      "docker"
    ]
  },
  "alwaysThinkingEnabled": true,
  "advisorModel": "opus",
  "showClearContextOnPlanAccept": true,
  "autoUpdatesChannel": "latest",
  "autoMemoryEnabled": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true,
  "teammateMode": "in-process",
  "terminalProgressBarEnabled": true,
  "model": "opus[1m]"
}
