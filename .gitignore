# Ignore everything by default
*

# Whitelist user-authored configuration
!.claude/
!.claude/settings.local.json
!.gitignore
!.mcp.json
!CLAUDE.md
!bash-style-guide.md
!code-principles.md
!decompose-reference.md
!reasoning-principles.md
!settings.json

# Whitelist agents
!agents/
!agents/**

# Whitelist workflows
!workflows/
!workflows/**

# Whitelist custom skills (not symlinks)
!skills/
!skills/stax/
!skills/stax/**

# Whitelist team config (not inboxes)
!teams/
!teams/*/
!teams/*/config.json

# Whitelist memory files (global + agent, not project-specific)
!memory/
!memory/**
!agent-memory/
!agent-memory/**

